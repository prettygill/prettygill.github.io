<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>THE INSIDE JOB // CLASSIFIED</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Orbitron:wght@400;700;900&family=VT323&display=swap" rel="stylesheet">
<style>
:root {
  --bg:       #050a05;
  --bg2:      #080f08;
  --panel:    #0a140a;
  --border:   #1a3a1a;
  --green:    #00ff41;
  --green2:   #00cc33;
  --green3:   #009922;
  --green4:   #004410;
  --dimgreen:  #005515;
  --amber:    #ffb000;
  --red:      #ff2222;
  --red2:     #aa1111;
  --cyan:     #00ffee;
  --white:    #ccffcc;
  --muted:    #336633;
  --scanline: rgba(0,255,65,0.03);
}

@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }
@keyframes scanlines { 0%{background-position:0 0} 100%{background-position:0 4px} }
@keyframes flicker { 0%,100%{opacity:1} 92%{opacity:1} 93%{opacity:0.85} 94%{opacity:1} 97%{opacity:0.9} 98%{opacity:1} }
@keyframes fadeIn { from{opacity:0;transform:translateY(6px)} to{opacity:1;transform:translateY(0)} }
@keyframes glitch {
  0%,100%{clip-path:inset(0 0 98% 0);transform:translate(-2px,0)}
  20%{clip-path:inset(30% 0 60% 0);transform:translate(2px,0)}
  40%{clip-path:inset(70% 0 10% 0);transform:translate(-1px,0)}
  60%{clip-path:inset(10% 0 85% 0);transform:translate(3px,0)}
  80%{clip-path:inset(50% 0 30% 0);transform:translate(-2px,0)}
}
@keyframes typing { from{width:0} to{width:100%} }
@keyframes pulse { 0%,100%{box-shadow:0 0 0 0 rgba(0,255,65,0.4)} 50%{box-shadow:0 0 0 6px rgba(0,255,65,0)} }

*{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}

body {
  background: var(--bg);
  color: var(--green);
  font-family: 'Share Tech Mono', monospace;
  font-size: 14px;
  line-height: 1.75;
  min-height: 100vh;
  overflow-x: hidden;
  animation: flicker 8s infinite;
  cursor: crosshair;
}

/* CRT scanlines overlay */
body::after {
  content:'';
  position:fixed;
  inset:0;
  background: repeating-linear-gradient(
    0deg,
    transparent,
    transparent 2px,
    var(--scanline) 2px,
    var(--scanline) 4px
  );
  pointer-events:none;
  z-index:9000;
  animation: scanlines 0.1s linear infinite;
}

/* Vignette */
body::before {
  content:'';
  position:fixed;
  inset:0;
  background: radial-gradient(ellipse at center, transparent 60%, rgba(0,0,0,0.7) 100%);
  pointer-events:none;
  z-index:9001;
}

/* ── PROGRESS ── */
#pgbar {
  position:fixed;top:0;left:0;height:2px;
  background: linear-gradient(90deg, var(--green3), var(--green), var(--cyan));
  z-index:9999;
  transition:width 0.5s;
  box-shadow: 0 0 8px var(--green);
}

/* ── STATUS BAR ── */
#statusbar {
  position:fixed;top:0;left:0;right:0;
  height:22px;
  background: var(--bg2);
  border-bottom:1px solid var(--border);
  display:flex;justify-content:space-between;align-items:center;
  padding:0 1rem;
  font-size:10px;
  color:var(--green3);
  z-index:8000;
  letter-spacing:0.15em;
}
#statusbar .blink { animation: blink 1s step-end infinite; }
#statusbar .red { color: var(--red); }

/* ── MAIN CONTAINER ── */
.terminal {
  max-width: 900px;
  margin: 0 auto;
  padding: 2.5rem 1.5rem 5rem;
  padding-top: 3rem;
}

/* ── BOOT SCREEN / COVER ── */
#cover {
  display:block;
  border: 1px solid var(--border);
  background: var(--panel);
  padding: 2.5rem;
  margin-bottom: 1rem;
  position:relative;
  box-shadow: 0 0 30px rgba(0,255,65,0.06), inset 0 0 60px rgba(0,20,0,0.5);
}

.cover-classified {
  text-align:center;
  margin-bottom:2rem;
  padding:0.6rem;
  border:2px solid var(--red2);
  color:var(--red);
  font-family:'Orbitron',sans-serif;
  font-size:0.72rem;
  letter-spacing:0.5em;
  text-transform:uppercase;
  box-shadow: 0 0 15px rgba(255,34,34,0.2), inset 0 0 15px rgba(255,34,34,0.05);
}

.cover-title-block { text-align:center; margin: 2rem 0; }
.cover-title-block .case-num {
  font-family:'Share Tech Mono',monospace;
  font-size:0.72rem;
  color:var(--muted);
  letter-spacing:0.3em;
  margin-bottom:0.5rem;
}
.cover-title-block h1 {
  font-family:'VT323',monospace;
  font-size:clamp(3.5rem,10vw,6.5rem);
  color:var(--green);
  line-height:0.9;
  text-shadow: 0 0 20px var(--green), 0 0 40px rgba(0,255,65,0.3);
  letter-spacing:0.05em;
  position:relative;
}
/* glitch layer */
.cover-title-block h1::before {
  content: attr(data-text);
  position:absolute;
  left:0;right:0;
  color:var(--cyan);
  opacity:0.4;
  animation: glitch 4s infinite;
}
.cover-title-block .subtitle {
  font-family:'Share Tech Mono',monospace;
  font-size:0.78rem;
  color:var(--green3);
  letter-spacing:0.2em;
  margin-top:0.8rem;
}

.cover-grid {
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:1rem;
  margin:2rem 0;
  border-top:1px solid var(--border);
  padding-top:1.5rem;
}
@media(max-width:600px){.cover-grid{grid-template-columns:1fr;}}
.cover-field {
  padding:0.8rem;
  border:1px solid var(--border);
  background: rgba(0,255,65,0.02);
}
.cover-field .label {
  font-size:0.62rem;
  letter-spacing:0.25em;
  color:var(--muted);
  text-transform:uppercase;
  margin-bottom:0.3rem;
}
.cover-field .value {
  color:var(--white);
  font-size:0.88rem;
}
.cover-field .value.red { color:var(--red); }
.cover-field .value.amber { color:var(--amber); }

.boot-btn {
  display:block;
  margin:2rem auto 0;
  background:none;
  border:1px solid var(--green);
  color:var(--green);
  font-family:'Share Tech Mono',monospace;
  font-size:0.78rem;
  letter-spacing:0.3em;
  text-transform:uppercase;
  padding:0.9rem 2.5rem;
  cursor:pointer;
  transition:all 0.2s;
  box-shadow: 0 0 10px rgba(0,255,65,0.1);
  animation: pulse 2s infinite;
}
.boot-btn:hover {
  background:var(--green);
  color:var(--bg);
  box-shadow:0 0 20px rgba(0,255,65,0.5);
}

/* ── TOC ── */
#toc {
  display:none;
  border:1px solid var(--border);
  background:var(--panel);
  padding:2rem;
  margin-bottom:1rem;
}
#toc.visible { display:block; animation:fadeIn 0.3s ease; }

.toc-header {
  border-bottom:1px solid var(--border);
  padding-bottom:1rem;
  margin-bottom:1.5rem;
}
.toc-header h2 {
  font-family:'Orbitron',sans-serif;
  font-size:1rem;
  color:var(--green);
  letter-spacing:0.2em;
  text-shadow:0 0 10px rgba(0,255,65,0.4);
}
.toc-header p { font-size:0.75rem; color:var(--muted); margin-top:0.3rem; }

.toc-item {
  display:flex;
  align-items:center;
  gap:1rem;
  padding:0.7rem 0.5rem;
  border-bottom:1px solid var(--green4);
  cursor:pointer;
  transition:all 0.15s;
}
.toc-item:hover {
  background:rgba(0,255,65,0.05);
  padding-left:1rem;
  border-color:var(--green3);
}
.toc-item:hover .toc-num { color:var(--green); }
.toc-num { font-family:'Orbitron',sans-serif; font-size:0.75rem; color:var(--green3); min-width:2.5rem; }
.toc-name { font-size:0.88rem; color:var(--white); flex:1; }
.toc-cat { font-size:0.65rem; color:var(--muted); letter-spacing:0.1em; }
.toc-arrow { color:var(--green3); font-size:0.8rem; }
.toc-item:hover .toc-arrow { color:var(--green); }

/* ── CHAPTER PANELS ── */
.ch-panel {
  display:none;
  border:1px solid var(--border);
  background:var(--panel);
  padding:2rem 2.2rem;
  margin-bottom:1rem;
  animation:fadeIn 0.35s ease;
  position:relative;
}
.ch-panel.visible { display:block; }

/* Corner brackets */
.ch-panel::before,.ch-panel::after {
  content:'';
  position:absolute;
  width:12px;height:12px;
}
.ch-panel::before { top:-1px;left:-1px; border-top:2px solid var(--green);border-left:2px solid var(--green); }
.ch-panel::after { bottom:-1px;right:-1px; border-bottom:2px solid var(--green);border-right:2px solid var(--green); }

.ch-header {
  border-bottom:1px solid var(--border);
  padding-bottom:1rem;
  margin-bottom:2rem;
  display:flex;
  flex-direction:column;
  gap:0.3rem;
}
.ch-tag {
  font-size:0.6rem;
  letter-spacing:0.35em;
  color:var(--green3);
  text-transform:uppercase;
}
.ch-title {
  font-family:'Orbitron',sans-serif;
  font-size:clamp(1.3rem,3.5vw,2rem);
  color:var(--green);
  letter-spacing:0.08em;
  text-shadow:0 0 15px rgba(0,255,65,0.35);
  line-height:1.1;
}
.ch-sub {
  font-size:0.75rem;
  color:var(--muted);
  font-style:italic;
}
.ch-header-line {
  display:flex;gap:3px;margin-top:0.6rem;
}
.ch-header-line span { height:2px;background:var(--green); }
.ch-header-line span:first-child { flex:1; }
.ch-header-line span:last-child { width:20px;background:var(--cyan); }

/* ── STORY TEXT ── */
.story p { margin-bottom:1rem; color:var(--white); font-size:0.9rem; line-height:1.85; }
.story p.log { color:var(--green3); font-size:0.85rem; }
.story p.log::before { content:'>> '; color:var(--green); }
.story h3 {
  font-family:'Orbitron',sans-serif;
  font-size:0.9rem;
  letter-spacing:0.15em;
  color:var(--green);
  margin:2rem 0 0.8rem;
  text-transform:uppercase;
  border-left:3px solid var(--green);
  padding-left:0.8rem;
  text-shadow:0 0 8px rgba(0,255,65,0.3);
}

/* ── ALERT BOX ── */
.alert-box {
  border:1px solid var(--red2);
  padding:1rem 1.3rem;
  margin:1.5rem 0;
  background:rgba(255,34,34,0.04);
  position:relative;
}
.alert-box::before {
  content:'⚠ ALERT';
  position:absolute;
  top:-0.55rem;left:0.8rem;
  background:var(--panel);
  padding:0 0.4rem;
  font-size:0.6rem;
  letter-spacing:0.2em;
  color:var(--red);
}
.alert-box p { color:var(--red); font-size:0.88rem; margin:0; }

/* ── TERMINAL LOG (Det. Mark annotation) ── */
.terminal-log {
  background:rgba(0,255,65,0.03);
  border:1px solid var(--green4);
  border-left:3px solid var(--green);
  padding:1rem 1.3rem;
  margin:1.5rem 0;
  font-size:0.85rem;
  color:var(--green2);
}
.terminal-log .prompt { color:var(--green); margin-bottom:0.3rem; font-size:0.72rem; letter-spacing:0.15em; }
.terminal-log p { color:var(--green2); margin:0; }

/* ── COURSE BOX ── */
.course-box {
  background:rgba(0,204,255,0.03);
  border:1px solid rgba(0,255,238,0.2);
  border-left:3px solid var(--cyan);
  padding:1rem 1.3rem;
  margin:1.5rem 0;
}
.course-box .label { font-size:0.6rem;letter-spacing:0.25em;color:var(--cyan);margin-bottom:0.4rem;text-transform:uppercase; }
.course-box p { font-size:0.87rem; color:rgba(0,255,238,0.8); margin:0; }

/* ── WANTED / SUSPECT PROFILE ── */
.suspect {
  border:1px solid var(--red2);
  padding:1.3rem 1.5rem;
  margin:2rem 0;
  background:rgba(255,34,34,0.03);
  position:relative;
}
.suspect::before {
  content:'// SUSPECT PROFILE';
  position:absolute;top:-0.6rem;left:1rem;
  background:var(--panel);padding:0 0.5rem;
  font-size:0.6rem;letter-spacing:0.25em;color:var(--red);
}
.suspect-name {
  font-family:'Orbitron',sans-serif;
  font-size:1.8rem;
  color:var(--red);
  text-shadow:0 0 15px rgba(255,34,34,0.4);
  margin:0.3rem 0;
}
.suspect table { width:100%;margin-top:0.8rem; }
.suspect td { padding:0.25rem 0.5rem;font-size:0.82rem; }
.suspect td:first-child { color:var(--muted);width:120px;font-size:0.72rem;letter-spacing:0.1em; }
.suspect td:last-child { color:var(--white); }
.suspect .status { color:var(--red);font-weight:bold; }

/* ── DATA TABLE ── */
.data-table { width:100%;border-collapse:collapse;margin:1.2rem 0;font-size:0.82rem; }
.data-table th {
  background:rgba(0,255,65,0.08);
  color:var(--green);
  font-size:0.72rem;
  letter-spacing:0.12em;
  text-transform:uppercase;
  padding:0.6rem 0.9rem;
  text-align:left;
  border:1px solid var(--border);
  border-bottom:1px solid var(--green3);
}
.data-table td {
  padding:0.55rem 0.9rem;
  border:1px solid var(--border);
  color:var(--white);
  vertical-align:top;
  line-height:1.6;
}
.data-table tr:nth-child(even) td { background:rgba(0,255,65,0.02); }
.data-table td.flag { color:var(--red); }

/* ── DISPATCH ── */
.dispatch {
  background:rgba(255,176,0,0.04);
  border:1px solid rgba(255,176,0,0.25);
  padding:1rem 1.3rem;
  margin:1.5rem 0;
  font-size:0.86rem;
  color:var(--amber);
  position:relative;
}
.dispatch::before {
  content:'// DISPATCH';
  display:block;
  font-size:0.6rem;letter-spacing:0.25em;
  margin-bottom:0.5rem;
  padding-bottom:0.4rem;
  border-bottom:1px solid rgba(255,176,0,0.2);
}

/* ── CASE FILE ── */
.case-box {
  border:1px solid var(--border);
  padding:1.3rem 1.5rem;
  margin:1.8rem 0;
  position:relative;
  background:rgba(0,255,65,0.015);
}
.case-box::before {
  content: attr(data-label);
  position:absolute;top:-0.6rem;left:1rem;
  background:var(--panel);padding:0 0.5rem;
  font-size:0.6rem;letter-spacing:0.2em;color:var(--green3);text-transform:uppercase;
}
.case-box h4 {
  font-family:'Orbitron',sans-serif;
  font-size:0.85rem;
  letter-spacing:0.12em;
  color:var(--green);
  margin-bottom:0.8rem;
  text-transform:uppercase;
}
.case-box p,.case-box li { font-size:0.87rem;color:var(--white);margin-bottom:0.4rem;line-height:1.65; }
.case-box ul { padding-left:1.5rem; }
.case-box li { list-style:'▸ ';margin-bottom:0.5rem; }
.case-box li strong { color:var(--green); }

/* ── WITNESS GRID ── */
.witness-grid {
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:1px;
  margin:1rem 0;
  background:var(--border);
}
@media(max-width:580px){.witness-grid{grid-template-columns:1fr;gap:0.8rem;background:none;}}
.witness {
  padding:1.2rem;
  background:var(--panel);
}
.witness .w-label {
  font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;
  margin-bottom:0.6rem;padding-bottom:0.4rem;
  border-bottom:1px solid var(--border);
}
.witness.for .w-label { color:var(--green3); }
.witness.against .w-label { color:var(--amber); }
.witness p { font-size:0.83rem;color:var(--white);line-height:1.65; }

.assessment {
  background:rgba(0,255,65,0.04);
  border-top:1px solid var(--green3);
  padding:0.9rem 1.2rem;
  font-size:0.85rem;
  color:var(--green2);
}
.assessment .a-label { font-size:0.6rem;letter-spacing:0.2em;color:var(--green);margin-bottom:0.3rem; }
.dispute-h {
  font-family:'Orbitron',sans-serif;
  font-size:0.8rem;letter-spacing:0.12em;
  color:var(--amber);margin:2.5rem 0 0.3rem;
  text-transform:uppercase;
  border-bottom:1px solid rgba(255,176,0,0.2);
  padding-bottom:0.5rem;
}
.dispute-sub { font-size:0.75rem;color:var(--muted);margin-bottom:1rem; }

/* ── Q&A ── */
.qa-item {
  border:1px solid var(--border);
  margin-bottom:0.7rem;
  background:var(--bg2);
  overflow:hidden;
  transition:border-color 0.2s;
}
.qa-item.open { border-color:var(--green3); }
.qa-q {
  display:flex;justify-content:space-between;align-items:flex-start;
  gap:0.8rem;padding:1rem 1.1rem;cursor:pointer;transition:background 0.15s;
}
.qa-q:hover { background:rgba(0,255,65,0.04); }
.qa-q-text { flex:1;color:var(--white);font-size:0.87rem;line-height:1.6; }
.qa-meta { display:flex;flex-direction:column;align-items:flex-end;gap:0.3rem;min-width:75px; }
.qa-badge {
  font-size:0.55rem;letter-spacing:0.1em;text-transform:uppercase;
  padding:0.2rem 0.4rem;border:1px solid;white-space:nowrap;
}
.b-recall { border-color:var(--green3);color:var(--green3); }
.b-apply  { border-color:var(--cyan);color:var(--cyan); }
.b-tf     { border-color:var(--amber);color:var(--amber); }
.b-think  { border-color:var(--red);color:var(--red); }
.qa-arrow { color:var(--green3);font-size:0.8rem;transition:transform 0.2s;margin-top:2px; }
.qa-item.open .qa-arrow { transform:rotate(90deg);color:var(--green); }
.qa-a { display:none;padding:0.9rem 1.1rem 1.2rem;border-top:1px dashed var(--border); }
.qa-item.open .qa-a { display:block; }
.qa-a-label { font-size:0.58rem;letter-spacing:0.2em;color:var(--green);margin-bottom:0.5rem;text-transform:uppercase; }
.qa-a p { font-size:0.85rem;color:var(--white);margin-bottom:0.4rem;line-height:1.7; }
.qa-a strong { color:var(--green2); }

/* ── SOURCES ── */
.sources {
  border-top:1px solid var(--border);
  margin-top:2rem;
  padding-top:1rem;
}
.sources-label { font-size:0.58rem;letter-spacing:0.25em;color:var(--green3);text-transform:uppercase;margin-bottom:0.7rem; }
.sources p { font-size:0.73rem;color:var(--muted);line-height:1.65;margin-bottom:0.35rem; }

/* ── GRAPHIC BLOCKS ── */
.graphic-block { margin:2rem 0;border:1px solid var(--border);background:var(--bg2);padding:0.8rem; }
.graphic-block svg { width:100%;height:auto;display:block; }
.graphic-block figcaption {
  font-size:0.72rem;color:var(--green3);
  margin-top:0.6rem;text-align:center;
  border-top:1px solid var(--border);padding-top:0.5rem;
  letter-spacing:0.05em;
}

/* ── NAV ── */
.nav-controls {
  display:flex;justify-content:space-between;align-items:center;
  margin-top:2rem;padding-top:1.5rem;
  border-top:1px solid var(--border);gap:1rem;
}
.nav-btn {
  background:none;border:1px solid var(--green3);
  color:var(--green3);
  font-family:'Share Tech Mono',monospace;
  font-size:0.72rem;letter-spacing:0.15em;text-transform:uppercase;
  padding:0.6rem 1.1rem;cursor:pointer;transition:all 0.18s;
}
.nav-btn:hover:not(:disabled) { border-color:var(--green);color:var(--green);background:rgba(0,255,65,0.06);box-shadow:0 0 10px rgba(0,255,65,0.2); }
.nav-btn:disabled { opacity:0.25;cursor:default; }
.nav-pg { font-size:0.75rem;color:var(--muted);letter-spacing:0.1em; }

.term { color:var(--green);font-weight:bold;border-bottom:1px dotted var(--green3); }

footer { text-align:center;padding:2rem;font-size:0.65rem;color:var(--green4);letter-spacing:0.15em; }
</style>
</head>
<body>

<div id="pgbar"></div>

<!-- STATUS BAR -->
<div id="statusbar">
  <span>SOMATIC CRIMES UNIT // PRECINCT 10 // SECURE TERMINAL</span>
  <span class="blink red">● CASE ACTIVE</span>
  <span id="clock"></span>
</div>

<div class="terminal">

<!-- ══════════════ COVER ══════════════ -->
<div id="cover">
  <div class="cover-classified">⬛ TOP SECRET // CLASSIFIED // EYES ONLY ⬛</div>

  <div class="cover-title-block">
    <div class="case-num">CASE FILE // SCU-10-∞ // OPENED: 600,000,000 BCE // STILL OPEN</div>
    <h1 data-text="THE INSIDE JOB">THE INSIDE JOB</h1>
    <div class="subtitle">A DETECTIVE STORY ABOUT CANCER AS AN EVOLUTIONARY TRADE-OFF</div>
  </div>

  <div class="cover-grid">
    <div class="cover-field">
      <div class="label">Investigating Officers</div>
